rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             request.auth.token.email != null &&
             (request.auth.token.email.lower() == "cihan.ozel10@gmail.com" || 
              request.auth.token.email.lower() == "cihanogretmen10@gmail.com");
    }

    function isParentOfStudent(teacherUid, studentId) {
      let student = get(/databases/$(database)/documents/users/$(teacherUid)/students/$(studentId)).data;
      return isAuthenticated() && 
             request.auth.token.email != null &&
             (student.parentEmail == request.auth.token.email || 
              (student.parentEmail2 != null && student.parentEmail2 == request.auth.token.email));
    }

    function isParentInClass(teacherUid) {
      // This is hard to check without studentId. 
      // For now, we'll allow reading non-sensitive class data if the user is a parent.
      // In a real app, we'd have a Parent-Teacher link collection.
      return isAuthenticated() && request.auth.token.email != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('profileType' in data) || data.profileType is string) &&
             (!('firstName' in data) || data.firstName is string) &&
             (!('lastName' in data) || data.lastName is string) &&
             (!('city' in data) || data.city is string) &&
             (!('district' in data) || data.district is string) &&
             (!('schoolName' in data) || data.schoolName is string) &&
             (!('gradeLevel' in data) || data.gradeLevel is string) &&
             (!('section' in data) || data.section is string) &&
             (!('isProfileComplete' in data) || data.isProfileComplete is bool) &&
             (!('theme' in data) || data.theme is string) &&
             (!('isDemo' in data) || data.isDemo is bool) &&
             (!('studentId' in data) || (data.studentId is string || data.studentId == null)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('lastLogin' in data) || data.lastLogin is timestamp);
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['studentNo', 'name', 'gender', 'teacherUid']) &&
             data.studentNo is string && data.studentNo.size() > 0 && data.studentNo.size() < 20 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('surname' in data) || (data.surname is string && data.surname.size() < 100)) &&
             data.gender in ['Erkek', 'Kız'] &&
             data.teacherUid == request.auth.uid &&
             (!('number' in data) || data.number is number) &&
             (!('school' in data) || data.school is string) &&
             (!('grade' in data) || data.grade is string) &&
             (!('section' in data) || data.section is string) &&
             (!('birthDate' in data) || data.birthDate is string) &&
             (!('active' in data) || data.active is bool) &&
             (!('avatar' in data) || data.avatar is string) &&
             (!('stars' in data) || data.stars is number) &&
             (!('starHistory' in data) || data.starHistory is list) &&
             (!('starAwards' in data) || data.starAwards is list) &&
             (!('parentEmail' in data) || data.parentEmail is string) &&
             (!('parentEmail2' in data) || data.parentEmail2 is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidStudentActivity(data) {
      return data.keys().hasAll(['title', 'rewardCategory', 'rewardAmount', 'type']) &&
             data.title is string &&
             data.rewardCategory is string &&
             data.rewardAmount is number &&
             data.type is string &&
             (!('description' in data) || data.description is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidScheduleConfig(data) {
      return data.keys().hasAll(['days', 'lessonCount', 'startTime', 'recessDuration', 'lunchBreakDuration', 'lessonDuration', 'lunchBreakAfterLesson']) &&
             data.days is list &&
             data.lessonCount is number &&
             data.startTime is string &&
             data.recessDuration is number &&
             data.lunchBreakDuration is number &&
             data.lessonDuration is number &&
             data.lunchBreakAfterLesson is number &&
             (!('customRecessDurations' in data) || data.customRecessDurations is map) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidSeatingConfig(data) {
      return data.groupCount is number &&
             data.peoplePerRow is number &&
             data.rowsPerGroup is list &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidSeatingPlan(data) {
      return data.plan is map &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidBook(data) {
      return data.registrationNo is number && data.registrationNo > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.teacherUid == request.auth.uid &&
             (!('author' in data) || data.author is string) &&
             (!('pageCount' in data) || data.pageCount is number) &&
             (!('status' in data) || data.status is string) &&
             (!('currentStudentId' in data) || data.currentStudentId is string || data.currentStudentId == null) &&
             (!('currentStudentName' in data) || data.currentStudentName is string || data.currentStudentName == null) &&
             (!('assignmentDate' in data) || data.assignmentDate is timestamp || data.assignmentDate == null) &&
             (!('isReadByAll' in data) || data.isReadByAll is bool) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidReadingRecord(data) {
      return data.bookId is string &&
             data.bookName is string &&
             (!('pageCount' in data) || data.pageCount is number || data.pageCount == null) &&
             data.studentId is string &&
             data.studentName is string &&
             data.startDate is timestamp &&
             (data.endDate is timestamp || data.endDate == null) &&
             data.teacherUid == request.auth.uid &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidReadingEvaluation(data) {
      return data.bookId is string &&
             data.studentId is string &&
             (!('readingScore' in data) || data.readingScore is number || data.readingScore == null) &&
             (!('tellingScore' in data) || data.tellingScore is number || data.tellingScore == null) &&
             (!('writingScore' in data) || data.writingScore is number || data.writingScore == null) &&
             (!('examScore' in data) || data.examScore is number || data.examScore == null) &&
             data.teacherUid == request.auth.uid &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidTournament(data) {
      return data.keys().hasAll(['name', 'type', 'matchType', 'fixtureType', 'currentRound', 'participants', 'status', 'teacherUid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             (!('description' in data) || data.description is string) &&
             data.type in ['Eleme', 'Lig', 'Grup', 'Grup+Eleme'] &&
             data.matchType in ['Tek Maç', 'Çift Maç'] &&
             data.fixtureType in ['all', 'round-by-round'] &&
             (!('winnerSelectionMethod' in data) || data.winnerSelectionMethod in ['winner', 'score']) &&
             data.currentRound is number &&
             data.participants is list &&
             (!('extraParticipants' in data) || data.extraParticipants is list) &&
             data.status in ['Devam Ediyor', 'Tamamlandı'] &&
             (!('winnerName' in data) || data.winnerName is string) &&
             data.teacherUid == request.auth.uid &&
             (!('pointsWin' in data) || data.pointsWin is number) &&
             (!('pointsDraw' in data) || data.pointsDraw is number) &&
             (!('pointsLoss' in data) || data.pointsLoss is number) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['tournamentId', 'round', 'player1Id', 'player2Id', 'status']) &&
             data.tournamentId is string &&
             data.round is number &&
             data.player1Id is string &&
             data.player2Id is string &&
             (!('player1Name' in data) || data.player1Name is string) &&
             (!('player2Name' in data) || data.player2Name is string) &&
             (!('winnerId' in data) || data.winnerId is string) &&
             (!('score1' in data) || data.score1 is number) &&
             (!('score2' in data) || data.score2 is number) &&
             data.status in ['pending', 'completed'] &&
             (!('nextMatchId' in data) || data.nextMatchId is string) &&
             (!('matchCode' in data) || data.matchCode is string) &&
             (!('isDoubleMatch' in data) || data.isDoubleMatch is bool) &&
             (!('pairCode' in data) || data.pairCode is string) &&
             (!('isTieBreaker' in data) || data.isTieBreaker is bool) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidLessonUnit(data) {
      return data.keys().hasAll(['lessonId', 'name', 'order', 'teacherUid']) &&
             data.lessonId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.order is number &&
             data.teacherUid == request.auth.uid &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidLessonOutcome(data) {
      return data.keys().hasAll(['unitId', 'lessonId', 'description', 'teacherUid']) &&
             data.unitId is string &&
             data.lessonId is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             (!('code' in data) || data.code is string) &&
             data.teacherUid == request.auth.uid &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidLessonQuestion(data) {
      return data.keys().hasAll(['lessonId', 'unitId', 'outcomeId', 'type', 'text', 'teacherUid']) &&
             data.lessonId is string &&
             data.unitId is string &&
             data.outcomeId is string &&
             data.type in ['multiple-choice', 'true-false', 'matching', 'fill-in-the-blanks'] &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             (!('options' in data) || data.options is list) &&
             (!('correctAnswer' in data) || data.correctAnswer is string) &&
             (!('pairs' in data) || data.pairs is list) &&
             data.teacherUid == request.auth.uid &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidExam(data) {
      return data.keys().hasAll(['lessonId', 'title', 'totalQuestions', 'examConfig', 'questions', 'status']) &&
             data.lessonId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.totalQuestions is number &&
             data.examConfig is list &&
             data.questions is list &&
             data.status in ['published', 'graded'] &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidExamResult(data) {
      return data.keys().hasAll(['studentId', 'score']) &&
             data.studentId is string &&
             data.score is number &&
             (!('answers' in data) || data.answers is list || data.answers is map) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidEsZitAnlamWord(data) {
      return data.keys().hasAll(['w', 'a', 'type']) &&
             data.w is string && data.w.size() > 0 && data.w.size() < 100 &&
             data.a is string && data.a.size() > 0 && data.a.size() < 100 &&
             data.type in ['es', 'zit'] &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['studentId', 'studentName', 'score', 'totalQuestions', 'timeMs', 'createdAt']) &&
             data.studentId is string &&
             data.studentName is string &&
             data.score is number &&
             data.totalQuestions is number &&
             data.timeMs is number &&
             data.createdAt is timestamp;
    }

    function isValidTeacherAnnouncement(data) {
      return data.keys().hasAll(['title', 'content', 'targetAudience', 'targetStudentIds', 'readBy']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.targetAudience in ['ALL', 'SPECIFIC'] &&
             data.targetStudentIds is list &&
             data.readBy is map &&
             (!('hasPoll' in data) || data.hasPoll is bool) &&
             (!('pollOptions' in data) || data.pollOptions is list) &&
             (!('pollVotes' in data) || data.pollVotes is map) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        allow create: if isAdmin() || (isAuthenticated() && request.resource.data.type == 'message');
      }

      match /remote_control/{docId} {
        allow read, write: if isAuthenticated();
      }

      match /exams/{examId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && isValidExam(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
        
        match /results/{resultId} {
          allow read: if isAuthenticated();
          allow create, update: if isOwner(userId) && isValidExamResult(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      match /config/{configId} {
        allow read: if isAuthenticated();
        allow delete: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && (
          (configId == 'schedule' && isValidScheduleConfig(request.resource.data)) ||
          (configId == 'scheduleData' && request.resource.data.slots is map) ||
          (configId == 'seating' && isValidSeatingConfig(request.resource.data)) ||
          (configId == 'seatingPlan' && isValidSeatingPlan(request.resource.data))
        );
      }

      match /books/{bookId} {
        allow read: if isAuthenticated();
        allow create, update: if request.auth.uid == userId && isValidBook(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      match /subjects/{subjectId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && 
                               request.resource.data.name is string && 
                               request.resource.data.name.size() > 0 &&
                               request.resource.data.color is string &&
                               request.resource.data.teacherUid == userId &&
                               (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp) &&
                               (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /students/{studentId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId) && isValidStudent(request.resource.data);
        allow update: if (isOwner(userId) && isValidStudent(request.resource.data)) ||
                        (isAuthenticated() && request.auth.token.email != null && (
                          // Allow parent to "claim" if field is null
                          ((resource.data.parentEmail == null && request.resource.data.parentEmail == request.auth.token.email && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentEmail'])) ||
                           (resource.data.parentEmail == request.auth.token.email && resource.data.parentEmail2 == null && request.resource.data.parentEmail2 == request.auth.token.email && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentEmail2'])))
                          ||
                          // Existing removal logic
                          ((resource.data.parentEmail == request.auth.token.email && request.resource.data.parentEmail == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentEmail'])) ||
                           (resource.data.parentEmail2 == request.auth.token.email && request.resource.data.parentEmail2 == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentEmail2'])))
                          ||
                          // Allow parent to update score (stars) for their own child
                          (isParentOfStudent(userId, studentId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stars']))
                        ));
        allow delete: if isOwner(userId) || isAdmin();

        match /activities/{activityId} {
          allow read: if isAuthenticated();
          allow create, update: if isOwner(userId) && isValidStudentActivity(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      match /readingRecords/{recordId} {
        allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isParentInClass(userId));
        allow create, update: if isOwner(userId) && isValidReadingRecord(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /readingEvaluations/{evaluationId} {
        allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isParentInClass(userId));
        allow create, update: if isOwner(userId) && isValidReadingEvaluation(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /tournaments/{tournamentId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && isValidTournament(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();

        match /matches/{matchId} {
          allow read: if isAuthenticated();
          allow create, update: if isOwner(userId) && isValidMatch(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      match /lessonUnits/{unitId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && isValidLessonUnit(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();

        match /leaderboard/{entryId} {
          allow read: if isAuthenticated();
          allow create, update: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      match /lessonOutcomes/{outcomeId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && isValidLessonOutcome(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /lessonQuestions/{questionId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && isValidLessonQuestion(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /activities/{activityId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && 
                               request.resource.data.name is string && 
                               request.resource.data.category in ["Türkçe", "Matematik", "Fen Bilimleri", "Sosyal Bilgiler", "Diğer"] &&
                               request.resource.data.teacherUid == userId;
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /activityInstances/{instanceId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId) && 
                               request.resource.data.activityId is string &&
                               request.resource.data.name is string &&
                               request.resource.data.type in ["Metin", "Şiir"] &&
                               request.resource.data.status in ["Planlandı", "Tamamlandı"] &&
                               request.resource.data.teacherUid == userId;
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /activityScores/{scoreId} {
        allow read: if isAuthenticated();
        allow create, update: if (isOwner(userId) || (isAuthenticated() && isParentOfStudent(userId, request.resource.data.studentId))) && 
                               request.resource.data.instanceId is string &&
                               request.resource.data.studentId is string &&
                               request.resource.data.totalScore is number &&
                               request.resource.data.teacherUid == userId;
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /esZitAnlamWords/{wordId} {
        allow get, list: if true;
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidEsZitAnlamWord(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /announcements/{announcementId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId) && isValidTeacherAnnouncement(request.resource.data);
        allow delete: if isOwner(userId);
        allow update: if (isOwner(userId) && isValidTeacherAnnouncement(request.resource.data)) || (
          isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'pollVotes']) &&
          isValidTeacherAnnouncement(request.resource.data)
        );
      }

      match /fenBilimleriQuestions/{qId} {
        allow read, write: if isOwner(userId);
      }
      match /hayatBilgisiQuestions/{qId} {
        allow read, write: if isOwner(userId);
      }
      match /matematikQuestions/{qId} {
        allow read, write: if isOwner(userId);
      }
      match /activitySettings/{settingId} {
        allow read, write: if isOwner(userId);
      }
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /cities/{cityId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.resource.data.name is string && request.resource.data.name.size() > 0;
    }

    match /districts/{districtId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.resource.data.name is string && request.resource.data.cityName is string;
    }

    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.resource.data.name is string && request.resource.data.cityName is string && request.resource.data.districtName is string;
    }

    match /welcome_campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
    }

    match /globalOutcomes/{outcomeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /globalQuestions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /presence/{presenceId} {
      allow read: if true;
      allow create, update: if isOwner(presenceId) || presenceId.matches('^anon_.*');
      allow delete: if isOwner(presenceId) || isAdmin() || presenceId.matches('^anon_.*');
    }

    match /daily_stats/{date} {
      allow read: if true;
      allow create, update: if true;
    }

    match /chats/{chatId} {
      allow read: if isAdmin() || (isAuthenticated() && (
        resource == null || 
        resource.data.teacherId == request.auth.uid || 
        resource.data.parentId == request.auth.uid
      ));
      allow create: if isAdmin() || (isAuthenticated() && (
        request.resource.data.teacherId == request.auth.uid || 
        request.resource.data.parentId == request.auth.uid
      ));
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.teacherId == request.auth.uid || 
        resource.data.parentId == request.auth.uid
      ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.teacherId == request.auth.uid);
      
      match /messages/{messageId} {
        allow read: if isAdmin() || (isAuthenticated() && (
          resource.data.teacherId == request.auth.uid || 
          resource.data.parentId == request.auth.uid
        ));
        allow create: if isAdmin() || (isAuthenticated() && (
          request.resource.data.teacherId == request.auth.uid || 
          request.resource.data.parentId == request.auth.uid
        ) && request.resource.data.senderId == request.auth.uid);
        allow update: if isAuthenticated() && 
          resource.data.senderId != request.auth.uid && 
          (resource.data.teacherId == request.auth.uid || resource.data.parentId == request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.teacherId == request.auth.uid);
      }
    }

    match /{path=**}/students/{studentId} {
      allow read: if isAdmin() || (isAuthenticated() && 
                  request.auth.token.email != null && 
                  (resource.data.parentEmail == request.auth.token.email || 
                   (resource.data.parentEmail2 != null && resource.data.parentEmail2 == request.auth.token.email)));
    }

    match /{path=**}/lessonQuestions/{questionId} {
      allow read: if isAdmin();
    }

    match /{path=**}/books/{bookId} {
      allow read: if isAdmin();
    }

    match /{path=**}/exams/{examId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/results/{resultId} {
      allow read: if isAuthenticated();
    }
  }
}
